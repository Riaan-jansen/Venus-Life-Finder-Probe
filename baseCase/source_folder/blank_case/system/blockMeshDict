FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// convertToMeters 1;

scale 0.1;

// user parameters to change size of boundary

radius 2.828427125;          // change radius here
nRadius -2.828427125;

zMin   -3;         // 
zMax    3;         //

a       2;   // R/sqrt(2)
nA     -2;

d       1;
nD     -1;  // inner cube size

// *********************


vertices
(
    // Bottom inner square
    ($d $d $zMin)
    ($nD $d $zMin)
    ($nD $nD $zMin)
    ($d $nD $zMin)

    // Bottom outer square
    ($a $a $zMin)
    ($nA $a $zMin)
    ($nA $nA $zMin)
    ($a $nA $zMin)

    // Top inner square
    ($d $d $zMax)
    ($nD $d $zMax)
    ($nD $nD $zMax)
    ($d $nD $zMax)

    // Top outer square
    ($a $a $zMax)
    ($nA $a $zMax)
    ($nA $nA $zMax)
    ($a $nA $zMax)
);


blocks
(
    hex (0 1 2 3 8 9 10 11) (20 20 40) simpleGrading (1 1 1)
    hex (0 3 7 4 8 11 15 12) (20 20 40) simpleGrading (1 1 1)
    hex (1 0 4 5 9 8 12 13) (20 20 40) simpleGrading (1 1 1)
    hex (2 1 5 6 10 9 13 14) (20 20 40) simpleGrading (1 1 1)
    hex (3 2 6 7 11 10 14 15) (20 20 40) simpleGrading (1 1 1)
);


edges
(
    arc 7 4  ($radius 0 $zMin)
    arc 15 12 ($radius 0 $zMax)

    arc 4 5  (0 $radius $zMin)
    arc 12 13 (0 $radius $zMax)

    arc 6 5  ($nRadius 0 $zMin)
    arc 14 13 ($nRadius 0 $zMax)

    arc 7 6  (0 $nRadius $zMin)
    arc 15 14 (0 $nRadius $zMax)
);


boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 3 2 1)
	    (3 0 4 7)
	    (1 5 4 0)
	    (2 6 5 1)
	    (3 7 6 2)
        );
    }
    
    outlet
    {
        type patch;
        faces
        (
            (8 9 10 11)
	    (8 11 15 12)
	    (9 8 12 13)
	    (10 9 13 14)
	    (11 10 14 15)
        );
    }
    outer
    {
        type wall;
        faces
        (
            (4 12 15 7)
	    (4 5 13 12)
	    (5 6 14 13)
	    (6 7 15 14)
        );
    }
);

