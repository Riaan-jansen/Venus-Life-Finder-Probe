FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "0";
    object      Urel;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

#include	"include/initialConditions"

internalField	uniform $flowVelocity;


boundaryField
{
    inlet
    {
        type            SRFVelocity;
        relative        false;
	    inletValue      uniform $flowVelocity;
        value           uniform $flowVelocity;
    }

    outlet
    {
	type           zeroGradient;
    }

    outer
    {
        type            SRFVelocity;
        relative        false;
	    inletValue      uniform $flowVelocity;
        value           uniform $flowVelocity;
    }

    seed
    {
	    type        noSlip;
    }
}


