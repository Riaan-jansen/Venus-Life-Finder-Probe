FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      nuTilda;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 6e-05;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 6e-05;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 6e-05;
        value           uniform 6e-05;
    }
    outer
    {
        type            zeroGradient;
    }
    seed
    {
        type            fixedValue;
        value           uniform 0;
    }
}


